# Copy to .env in this directory and fill in values. Single .env for backend + UI defaults (GET /config).

# JIRA
JIRA_URL=
JIRA_USERNAME=
JIRA_PASSWORD=
JIRA_TEST_PROJECT_KEY=
JIRA_TEST_ISSUE_TYPE=Test
JIRA_TEST_LINK_TYPE=Relates
JIRA_LINK_INWARD_IS_REQUIREMENT=true
JIRA_VERIFY_SSL=false

# Comma-separated issue type names for linked work (Story, Improvement, Feature, etc.).
JIRA_LINKED_WORK_ISSUE_TYPES=Story,Improvement,Feature

# true = no real JIRA; returns fixture ticket text; audit log is not written; memory is not saved on generate
MOCK=false

# UI: show History sidebar and Audit log (GET /config → frontend)
SHOW_MEMORY_UI=true
SHOW_AUDIT_UI=true

# Keycloak OIDC
USE_KEYCLOAK=false
KEYCLOAK_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_IDLE_TIMEOUT_MINUTES=60
# Leave empty for local API (JWKS uses KEYCLOAK_URL). docker-compose.yml sets host.docker.internal for the container only.
KEYCLOAK_INTERNAL_URL=

# LLM — OpenAI-compatible /v1/chat/completions. Local (LM Studio): URL below; cloud: e.g. https://api.openai.com/v1
LLM_URL=http://127.0.0.1:1234/v1
LLM_MODEL=qwen/qwen3-coder-30b
# API key for cloud providers (Bearer). Leave empty for local servers that do not require auth.
LLM_ACCESS_TOKEN=
# docker-compose.yml: overrides LLM_URL in the container (defaults to host.docker.internal). Set to match LLM_URL if needed.
DOCKER_LLM_URL=

# When exact memory key misses, match saved rows by similar title+description (0 = off; try 0.88–0.95)
MEMORY_SIMILARITY_THRESHOLD=0.92

# Priorities
PASTE_MODE_PRIORITIES='Highest, High, Medium, Low, Lowest'
